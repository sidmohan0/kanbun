# Required: Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: For website scraping and enrichment
# Get your API key from https://www.firecrawl.dev/
FIRECRAWL_API_KEY=your-firecrawl-api-key-here

# Optional: Database path (defaults to data/kanbun.db)
# DATABASE_PATH=data/kanbun.db

# Optional: Screenshot storage directory (defaults to data/screenshots)
# SCREENSHOTS_DIR=data/screenshots

# Optional: Demo mode uses a separate database with sample data (for testing/screenshots)
# DEMO_MODE=true
